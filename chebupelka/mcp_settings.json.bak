{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			},
			"alwaysAllow": [
				"query-docs",
				"resolve-library-id"
			]
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest",
				"--browser-url=http://192.168.0.116:9223"
			],
			"directTools": true
		},
		"pdf-reader": {
			"command": "npx",
			"args": [
				"@fabriqa.ai/pdf-reader-mcp"
			],
			"alwaysAllow": [
				"read-pdf",
				"search-pdf"
			]
		}
	}
}